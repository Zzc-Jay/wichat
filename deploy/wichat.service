[Unit]
Description=WiChat Backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/opt/wichat/backend
EnvironmentFile=/opt/wichat/backend/.env
ExecStart=/opt/wichat/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
